
# Database
DATABASE_URL=postgresql://voiceai:voiceai@localhost:5432/voiceai

# Redis
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000

# Database pool
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis pool
REDIS_POOL_MAX=20

# Embedding thread pool
EMBEDDING_THREAD_POOL_SIZE=4

# LLM fallback (para clasificación Route A/B)
LLM_FALLBACK_URL=
LLM_FALLBACK_API_KEY=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
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_FALLBACK_TIMEOUT_S=2.0
LLM_FALLBACK_MAX_CONNECTIONS=10

# Conversation history
MAX_HISTORY_TURNS=10
MAX_HISTORY_CHARS=2000

# Context-aware routing
ROUTING_CONTEXT_WINDOW=1
ROUTING_SHORT_TEXT_CHARS=20
LLM_CONTEXT_WINDOW=3

# OpenAI Realtime (para STT/TTS real)
OPENAI_API_KEY=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
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Server VAD (Voice Activity Detection)
VAD_SILENCE_DURATION_MS=200
VAD_THRESHOLD=0.6

# Calls
MAX_CONCURRENT_CALLS=50

# Router registry
ROUTER_REGISTRY_PATH=router_registry/v1

# Observability (opcional)
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=voice-ai-runtime
SENTRY_DSN=

# RabbitMQ Consumer (connects to external RabbitMQ instance / Amazon MQ)
RABBITMQ_URL=amqps://cls-user:t!XbUQpzMQpFXThFeH5j@b-252ce6ff-d18f-422c-880a-70ec717efb12.mq.eu-west-1.on.aws:5671/
RABBITMQ_CONSUME_QUEUE_NAME=csl-transcription-queue
RABBITMQ_PUBLISH_QUEUE_NAME=csl-maind-queue
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_ENABLED=true